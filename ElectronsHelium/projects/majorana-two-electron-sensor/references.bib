% --- Added: parity-readout / quasiparticle-poisoning literature (answers the notes.md literature-
% check question on prior entangled/parity sensors for MZM signals) ---
@article{vanloo2026kitaev,
  title = {Single-Shot Parity Readout of a Minimal {Kitaev} Chain},
  author = {van Loo, Nick and Zatelli, Francesco and Steffensen, Gorm O. and Roovers, Bart and Wang, Guanzhong and Van Caekenberghe, Thomas and Bordin, Alberto and van Driel, David and Zhang, Yining and Huisman, Wietze D. and Badawy, Ghada and Bakkers, Erik P. A. M. and Mazur, Grzegorz P. and Aguado, Ram{\'o}n and Kouwenhoven, Leo P.},
  journal = {Nature},
  year = {2026},
  month = feb,
  doi = {10.1038/s41586-025-09927-7},
  eprint = {2507.01606},
  archivePrefix = {arXiv},
  note = {Quantum-capacitance (global, dispersive) single-shot parity readout of a two-site Kitaev-chain
    MZM pair; observes random-telegraph parity switching with lifetimes >1 ms. Direct precedent for
    the \emph{statistics} of an MZM parity-flip signal (telegraph process, not a static field) but an
    intrinsic/local probe of the topological device itself, not an external differential sensor —
    the literature gap this project's own approach would fill remains open.}
}

@article{ramanathan2026parity,
  title = {Quantum Parity Detectors: {A} Qubit-Based Particle-Detection Scheme with meV Thresholds for Rare-Event Searches},
  author = {Ramanathan, Karthik and Sandoval, Brandon J. and Parker, John E. and Joshi, Lalit M. and Beyer, Andrew D. and Echternach, Pierre M. and Rosenblum, Serge and Golwala, Sunil R.},
  journal = {APS Open Sci.},
  volume = {1},
  pages = {000013},
  year = {2026},
  month = may,
  eprint = {2405.17192},
  archivePrefix = {arXiv},
  note = {Closest existing precedent to this project's detection philosophy: a superconducting qubit's
    own quasiparticle-poisoning parity flip used as a rare-event/dark-matter detector. Uses a single
    qubit's intrinsic parity, not an entangled differential pair reading a nearby MZM — the
    entanglement/common-mode-rejection angle proposed here still appears novel relative to this.}
}

